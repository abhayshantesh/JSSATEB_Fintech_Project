# Supply Chain Intelligence Platform — backend configuration
#
# Copy this file to `.env` (same folder) and fill in your key to enable the
# live AI analyst. Without a key the platform still works fully — AI insights
# fall back to a deterministic, metric-driven engine and are labelled
# "rule-based" in the UI.

# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Model to use via OpenRouter (optional; sensible default if unset)
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
