# AI-Driven Institutional Financial Analytics — configuration
#
# Copy this file to `.env` (in this same project-root folder) and add your key
# to enable the live AI financial analyst. Without a key the app still works
# fully — AI insights fall back to a deterministic, metric-driven engine and are
# labelled "Rule-based" in the UI.

# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Model to use via OpenRouter (optional; sensible default if unset)
OPENROUTER_MODEL=anthropic/claude-3.5-haiku
